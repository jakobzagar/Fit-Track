{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",

        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "types": ["node"],
        "lib": ["ES2022"],

        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "skipLibCheck": true
    },
    "include": ["src", "generated"],
    "exclude": ["node_modules", "dist"]
}
