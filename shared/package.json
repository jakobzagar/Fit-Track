{
    "name": "@fit-track/shared",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./auth": {
            "types": "./dist/auth.schemas.d.ts",
            "import": "./dist/auth.schemas.js"
        },
        "./exercises": {
            "types": "./dist/exercise.schemas.d.ts",
            "import": "./dist/exercise.schemas.js"
        },
        "./workouts": {
            "types": "./dist/workout.schemas.d.ts",
            "import": "./dist/workout.schemas.js"
        },
        "./workout-exercises": {
            "types": "./dist/workout-exercise.schemas.d.ts",
            "import": "./dist/workout-exercise.schemas.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "format": "prettier --config ../.prettierrc.json --ignore-path ../.prettierignore --write .",
        "format:check": "prettier --config ../.prettierrc.json --ignore-path ../.prettierignore --check ."
    },
    "peerDependencies": {
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "prettier": "^3.9.5",
        "typescript": "^6.0.3",
        "zod": "^4.4.3"
    }
}
